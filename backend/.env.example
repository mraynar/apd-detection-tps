# ==== backend/.env.example ====
# Template konfigurasi backend APD Detection.
# Salin file ini ke backend/.env dan isi nilai sesuai setup PostgreSQL lokal Anda.
#
#   cp backend/.env.example backend/.env   (Mac/Linux)
#   copy backend\.env.example backend\.env  (Windows CMD)
#
# JANGAN commit backend/.env ke git — file ini sudah ada di .gitignore.

# -----------------------------------------------------------------------
# DATABASE CONNECTION
# -----------------------------------------------------------------------
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Contoh lokal Windows (PostgreSQL default install):
#   DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/apd_detection
# Contoh lokal macOS (Homebrew, tanpa password):
#   DATABASE_URL=postgresql://localhost/apd_detection
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/apd_detection
