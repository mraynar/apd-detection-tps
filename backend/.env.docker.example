# ==== backend/.env.docker.example ====
# Template konfigurasi backend untuk deployment Docker.
# Salin ke backend/.env sebelum menjalankan docker compose.
#
#   cp backend/.env.docker.example backend/.env
#
# JANGAN commit backend/.env ke git — sudah ada di .gitignore.
# File ini (.env.docker.example) aman di-commit (tidak berisi credential nyata).

# -----------------------------------------------------------------------
# DATABASE CONNECTION — Supabase Cloud (AWS ap-southeast-1)
# -----------------------------------------------------------------------
# Format: postgresql://[user].[project_ref]:[password]@[host]:[port]/[database]
#
# Gunakan connection string Supabase langsung — tidak perlu host.docker.internal
# karena Supabase sudah cloud (bukan PostgreSQL lokal).
#
# Temukan connection string di:
#   Supabase Dashboard → Project Settings → Database → Connection string → URI
#   (pilih mode "Transaction" / port 6543 untuk connection pooling via PgBouncer,
#    atau mode "Session" / port 5432 untuk connection langsung)
#
# Contoh (Transaction mode / pooling — direkomendasikan untuk produksi):
DATABASE_URL=postgresql://postgres.SUPABASE_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------
# CORS ORIGINS
# -----------------------------------------------------------------------
# Comma-separated list of origins yang diizinkan mengakses backend.
# Ganti dengan IP/domain server Anda. Localhost sudah ditambahkan otomatis
# oleh backend sebagai fallback (tidak perlu ditulis di sini).
#
# Contoh:
#   CORS_ORIGINS=http://192.168.1.100:3000,https://apd.tps.co.id
CORS_ORIGINS=http://YOUR_SERVER_IP:3000
