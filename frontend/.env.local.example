# ==== frontend/.env.local.example ====
# Template konfigurasi frontend APD Detection.
# Salin file ini ke frontend/.env.local dan sesuaikan.
#
#   cp frontend/.env.local.example frontend/.env.local   (Mac/Linux)
#   copy frontend\.env.local.example frontend\.env.local  (Windows CMD)
#
# JANGAN commit frontend/.env.local ke git — sudah ada di .gitignore.

# -----------------------------------------------------------------------
# URL BACKEND FLASK
# -----------------------------------------------------------------------
# Untuk development lokal, gunakan http://localhost:5001
# Ganti ke IP/hostname sesuai jika backend berjalan di mesin lain.
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001
