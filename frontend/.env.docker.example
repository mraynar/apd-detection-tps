# ==== frontend/.env.docker.example ====
# Template konfigurasi frontend untuk deployment Docker.
# Salin ke frontend/.env.local sebelum menjalankan docker compose.
#
#   cp frontend/.env.docker.example frontend/.env.local
#
# JANGAN commit frontend/.env.local ke git — sudah ada di .gitignore.

# -----------------------------------------------------------------------
# URL BACKEND — PENTING: harus URL yang dapat dijangkau dari BROWSER pengguna
# -----------------------------------------------------------------------
# Ini adalah NEXT_PUBLIC_ variable — ter-embed ke dalam JavaScript bundle saat build.
# Harus berisi IP atau domain server yang dapat diakses dari browser klien.
#
# Di Docker: frontend dan backend jalan di server yang sama → pakai IP server.
# Contoh: NEXT_PUBLIC_BACKEND_URL=http://192.168.1.100:5001
#
# BUKAN http://backend:5001 — itu nama service internal Docker, tidak bisa
# diakses dari browser di luar container.
NEXT_PUBLIC_BACKEND_URL=http://YOUR_SERVER_IP:5001
